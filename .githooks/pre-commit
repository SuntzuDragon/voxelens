#!/usr/bin/env bash
#
# voxelens pre-commit hook — mirrors the CI gates so broken code never lands.
# Runs from the repo root against the working tree.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass in an emergency:  git commit --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Skip the (slow) cargo gates for commits that touch no Rust/build files,
# e.g. docs-only changes.
staged="$(git diff --cached --name-only)"
if ! printf '%s\n' "$staged" | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$'; then
    echo "pre-commit: no Rust changes staged — skipping cargo gates"
    exit 0
fi

echo "pre-commit: cargo fmt --check"
if ! cargo fmt --all -- --check; then
    echo "pre-commit: formatting check failed — run 'cargo fmt --all' and re-stage" >&2
    exit 1
fi

echo "pre-commit: cargo clippy -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "pre-commit: cargo test"
cargo test --all --quiet

echo "pre-commit: all checks passed"
